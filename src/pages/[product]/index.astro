---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHead from '../../components/PageHead.astro';
import ProductCard from '../../components/ProductCard.astro';
import StatusPill from '../../components/StatusPill.astro';
import RevealScript from '../../components/RevealScript.astro';
import {
  PRODUCTS,
  productsInLayer,
  layerById,
  STATUS_LABEL,
  type Product,
} from '../../data/products';
import { problemById } from '../../data/problems';

export function getStaticPaths() {
  return PRODUCTS.map((product) => ({
    params: { product: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}
const { product } = Astro.props;
const layer = layerById(product.layer);
const related = productsInLayer(product.layer).filter((p) => p.slug !== product.slug);
const kills = product.kills.map((id) => problemById(id)).filter((p) => p !== undefined);
const isSoon = product.status === 'coming-soon';

const docsHref = product.docs ?? (product.home ?? `/${product.slug}/docs/`);
const primary = product.docs
  ? { href: product.docs, label: 'Read the docs', ext: true }
  : product.home
    ? { href: product.home, label: `Visit ${product.name}`, ext: true }
    : product.repo
      ? { href: product.repo, label: isSoon ? 'Watch on GitHub' : 'View on GitHub', ext: true }
      : { href: '/products/', label: 'All tools', ext: false };

const meta: { k: string; v: string; href?: string }[] = [
  { k: 'Layer', v: layer.name, href: '/#stack' },
  { k: 'Status', v: STATUS_LABEL[product.status] },
];
if (product.kind) meta.push({ k: 'Kind', v: product.kind });
if (product.home) meta.push({ k: 'Home', v: product.home.replace(/^https?:\/\//, ''), href: product.home });
if (product.repo) meta.push({ k: 'Source', v: 'GitHub', href: product.repo });
---

<BaseLayout
  title={`${product.name} — ${product.tagline} — Sneat.dev`}
  description={product.blurb}
>
  <PageHead eyebrow={`${layer.name} layer · ${STATUS_LABEL[product.status]}`} title={product.name} lead={product.tagline}>
    <div class="p-actions">
      <a class="btn btn-primary" href={primary.href} rel={primary.ext ? 'noopener' : undefined} target={primary.ext ? '_blank' : undefined}>
        {primary.label}{primary.ext ? ' ↗' : ''}
      </a>
      {product.repo && primary.href !== product.repo && (
        <a class="btn btn-ghost" href={product.repo} rel="noopener" target="_blank">GitHub ↗</a>
      )}
      <a class="btn btn-ghost" href="/products/">← All tools</a>
    </div>
  </PageHead>

  <section class="section">
    <div class="container p-grid">
      <div class="p-main" data-reveal>
        {isSoon && (
          <div class="soon-banner">
            <StatusPill status="coming-soon" />
            <span>{product.name} is in the workshop. <a href="/cli/">Follow along →</a></span>
          </div>
        )}

        <p class="p-blurb">{product.blurb}</p>

        {kills.length > 0 && (
          <div class="p-kills">
            <h2>What it kills</h2>
            <ul>
              {kills.map((pr) => (
                <li>
                  <b>{pr!.name}.</b> {pr!.line}
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="p-docs">
          <h2>Documentation</h2>
          {product.docs || product.home ? (
            <p>
              {product.name} keeps its own home and docs at{' '}
              <a href={docsHref} rel="noopener" target="_blank">{docsHref.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗</a>.
              Everything on sneat.dev links back to the canonical source.
            </p>
          ) : (
            <p>
              Full docs are coming. For now, the specification and source live on{' '}
              <a href={product.repo ?? '/products/'} rel="noopener" target="_blank">GitHub ↗</a>,
              and <a href={`/${product.slug}/docs/`}>this page</a> will grow into the docs home.
            </p>
          )}
        </div>
      </div>

      <aside class="p-side" data-reveal data-reveal-delay="90">
        <div class="p-meta card">
          <h3 class="p-meta-title mono">Details</h3>
          <dl>
            {meta.map((m) => (
              <div class="p-meta-row">
                <dt>{m.k}</dt>
                <dd>
                  {m.href ? (
                    <a href={m.href} rel={m.href.startsWith('http') ? 'noopener' : undefined} target={m.href.startsWith('http') ? '_blank' : undefined}>{m.v}</a>
                  ) : (
                    m.v
                  )}
                </dd>
              </div>
            ))}
          </dl>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <div class="section-head" data-reveal>
          <p class="eyebrow">More in {layer.name}</p>
          <h2>{layer.question}</h2>
        </div>
        <div class="rel-grid">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}

  <RevealScript slot="scripts" />
</BaseLayout>

<style>
  .p-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }
  .p-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
  }
  .soon-banner {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.8rem 1rem;
    background: var(--ember-soft);
    border: 1px solid color-mix(in srgb, var(--ember) 30%, transparent);
    border-radius: var(--radius-sm);
    margin-bottom: 1.6rem;
    font-size: 0.95rem;
    color: var(--ember-strong);
  }
  .soon-banner a {
    color: var(--ember-strong);
    font-weight: 600;
  }
  .p-blurb {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 60ch;
  }
  .p-kills,
  .p-docs {
    margin-top: 2.2rem;
  }
  .p-kills h2,
  .p-docs h2 {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }
  .p-kills ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.7rem;
  }
  .p-kills li {
    padding-left: 1.2rem;
    position: relative;
    color: var(--color-text-muted);
  }
  .p-kills li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }
  .p-kills b {
    color: var(--color-text);
  }
  .p-meta {
    padding: 1.4rem 1.5rem;
    position: sticky;
    top: 84px;
  }
  .p-meta-title {
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 0 0 0.9rem;
  }
  .p-meta dl {
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .p-meta-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }
  .p-meta-row:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .p-meta dt {
    color: var(--color-text-faint);
  }
  .p-meta dd {
    margin: 0;
    text-align: right;
    font-weight: 550;
    word-break: break-word;
  }
  .rel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    gap: 1.1rem;
  }
  @media (max-width: 820px) {
    .p-grid {
      grid-template-columns: 1fr;
    }
    .p-meta {
      position: static;
    }
  }
</style>
