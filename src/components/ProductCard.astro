---
import type { Product } from '../data/products';
import { problemById } from '../data/problems';
import StatusPill from './StatusPill.astro';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const killed = product.kills.map((id) => problemById(id)?.name).filter(Boolean).slice(0, 2);
const bg = `/photos/tools/${product.slug}.jpg`;
---

<a class="pcard card card--link" href={`/${product.slug}/`} style={`--card-bg:url('${bg}')`}>
  <div class="pcard-top">
    <h3>{product.name}</h3>
    <StatusPill status={product.status} />
  </div>
  <p class="pcard-tag">{product.tagline}</p>
  <p class="pcard-blurb">{product.blurb}</p>
  <div class="pcard-foot">
    {product.kind && <span class="pcard-kind mono">{product.kind}</span>}
    <span class="pcard-arrow" aria-hidden="true">→</span>
  </div>
  {
    killed.length > 0 && (
      <p class="pcard-kills mono">kills: {killed.join(' · ')}</p>
    )
  }
</a>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    padding: 1.4rem 1.5rem 1.25rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  /* The tool's background photo — desaturated + brightened so every card reads
     as the same neutral texture regardless of the source photo's colour. */
  .pcard::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: var(--card-bg);
    background-size: cover;
    background-position: center;
    filter: saturate(0.24) brightness(1.18) contrast(0.97);
    transition: transform 0.4s var(--ease, ease);
  }
  /* Veil over the photo — top-weighted so the image reads behind the header
     while the denser text lower down keeps a lighter backdrop. Lifts on hover. */
  .pcard::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      175deg,
      color-mix(in srgb, var(--color-surface) 66%, transparent) 0%,
      color-mix(in srgb, var(--color-surface) 75%, transparent) 52%,
      color-mix(in srgb, var(--color-surface) 84%, transparent) 100%
    );
    transition: opacity 0.28s var(--ease, ease);
  }
  .pcard > * {
    position: relative;
    z-index: 2;
  }
  .pcard:hover::after {
    opacity: 0.82;
  }
  .pcard:hover::before {
    transform: scale(1.04);
  }
  .pcard:hover {
    text-decoration: none;
  }
  .pcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .pcard-top h3 {
    margin: 0;
    font-size: 1.25rem;
  }
  .pcard-tag {
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    font-size: 0.98rem;
  }
  .pcard-blurb {
    color: var(--color-text-muted);
    font-size: 0.92rem;
    margin: 0 0 1.1rem;
    line-height: 1.55;
  }
  .pcard-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .pcard-kind {
    font-size: 0.74rem;
    color: var(--color-text-faint);
  }
  .pcard-arrow {
    color: var(--color-accent);
    font-weight: 700;
    transition: transform 0.15s var(--ease, ease);
  }
  .pcard:hover .pcard-arrow {
    transform: translateX(4px);
  }
  .pcard-kills {
    margin: 0.7rem 0 0;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--color-border);
    font-size: 0.72rem;
    color: var(--color-text-faint);
  }
</style>
