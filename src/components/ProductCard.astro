---
import { productPath, type Product } from '../data/products';
import { problemById } from '../data/problems';
import StatusPill from './StatusPill.astro';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const killed = product.kills.map((id) => problemById(id)?.name).filter(Boolean).slice(0, 2);

// Each tool card is a dark terminal window with its own deep colour + accent.
// Deep, muted backgrounds so the set stays cohesive; brighter accent per tool.
const THEME: Record<string, { bg: string; ac: string }> = {
  specscore: { bg: '#0c1a15', ac: '#34d399' },
  modelspec: { bg: '#111233', ac: '#8b8bff' },
  graphspec: { bg: '#191233', ac: '#b48bff' },
  codegrapher: { bg: '#0b1630', ac: '#5aa8ff' },
  dtql: { bg: '#08201e', ac: '#3fd6c9' },
  ingitdb: { bg: '#0d1b12', ac: '#5fd08a' },
  openvaultdb: { bg: '#0e1a26', ac: '#57bce0' },
  polymodel: { bg: '#160f2b', ac: '#a98bff' },
  dalgo: { bg: '#0d1420', ac: '#79b8ff' },
  'bots-go-framework': { bg: '#1b1026', ac: '#d98bd0' },
  chatwright: { bg: '#0c111d', ac: '#70ffd0' },
  rehearse: { bg: '#241016', ac: '#e34b63' },
  wb: { bg: '#12101c', ac: '#ff8a5c' },
};
const theme = THEME[product.slug] ?? { bg: '#101020', ac: '#8b8bff' };
---

<a
  class="pcard"
  href={productPath(product)}
  style={`--tc-bg:${theme.bg};--tc-ac:${theme.ac}`}
>
  <div class="pcard-bar">
    <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="pcard-label mono">{product.slug}</span>
    <StatusPill status={product.status} />
  </div>
  <div class="pcard-body">
    <h3>{product.name}</h3>
    <p class="pcard-tag">{product.tagline}</p>
    <p class="pcard-blurb">{product.blurb}</p>
    <div class="pcard-foot">
      {product.kind && <span class="pcard-kind mono">{product.kind}</span>}
      <span class="pcard-arrow" aria-hidden="true">→</span>
    </div>
    {killed.length > 0 && <p class="pcard-kills mono">kills: {killed.join(' · ')}</p>}
  </div>
</a>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: #fff;
    background: var(--tc-bg);
    border: 1px solid color-mix(in srgb, var(--tc-ac) 22%, #ffffff14);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 18px 40px -24px rgba(6, 6, 24, 0.55);
    transition: transform 0.18s var(--ease, ease), box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .pcard:hover {
    text-decoration: none;
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--tc-ac) 55%, transparent);
    box-shadow:
      0 26px 55px -26px rgba(6, 6, 24, 0.7),
      0 0 0 1px color-mix(in srgb, var(--tc-ac) 30%, transparent);
  }

  /* terminal title bar */
  .pcard-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    background: color-mix(in srgb, #ffffff 5%, var(--tc-bg));
    border-bottom: 1px solid #ffffff14;
  }
  .dots {
    display: inline-flex;
    gap: 6px;
    flex: 0 0 auto;
  }
  .dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ffffff2e;
  }
  .dots i:nth-child(1) {
    background: #ff5f57;
  }
  .dots i:nth-child(2) {
    background: #febc2e;
  }
  .dots i:nth-child(3) {
    background: #28c840;
  }
  .pcard-label {
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.5);
    margin-right: auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .pcard-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem 1.4rem 1.2rem;
  }
  .pcard-body h3 {
    margin: 0 0 0.45rem;
    font-size: 1.28rem;
    color: #fff;
  }
  .pcard-tag {
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 0.55rem;
    font-size: 0.98rem;
  }
  .pcard-blurb {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.92rem;
    margin: 0 0 1.1rem;
    line-height: 1.56;
  }
  .pcard-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .pcard-kind {
    font-size: 0.74rem;
    color: rgba(255, 255, 255, 0.44);
  }
  .pcard-arrow {
    color: var(--tc-ac);
    font-weight: 700;
    transition: transform 0.15s var(--ease, ease);
  }
  .pcard:hover .pcard-arrow {
    transform: translateX(4px);
  }
  .pcard-kills {
    margin: 0.75rem 0 0;
    padding-top: 0.7rem;
    border-top: 1px dashed #ffffff1f;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
  }
</style>
