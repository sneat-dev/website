---
import { PROBLEMS } from '../data/problems';
import { layerById } from '../data/products';
---

<section id="problems" class="section section--alt">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Sound familiar?</p>
      <h2>You’ll recognise at least three of these.</h2>
      <p>None of them is a tooling gap you can npm-install away in isolation. They’re all the same wound: context that’s scattered, unstructured, and rotting.</p>
    </div>

    <div class="prob-grid">
      {
        PROBLEMS.map((p, i) => (
          <article class="prob card" data-reveal data-reveal-delay={String((i % 3) * 80)}>
            <div class="prob-photo">
              <img src={p.photo} alt={p.alt} loading="lazy" decoding="async" width="900" height="563" />
              <span class="prob-idx mono">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="prob-body">
              <h3>{p.name}</h3>
              <p>{p.line}</p>
              <a class="prob-tag" href="#stack">
                Solved at the <b>{layerById(p.layer).name}</b> layer
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .prob-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .prob {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
  }
  .prob-photo {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .prob-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.82) contrast(1.03) brightness(0.94);
    transition: transform 0.5s var(--ease, ease);
  }
  .prob-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, color-mix(in srgb, var(--ink-950) 22%, transparent) 0%, transparent 34%, color-mix(in srgb, var(--ink-950) 30%, transparent) 100%);
    transition: opacity 0.3s var(--ease, ease);
  }
  .prob-idx {
    position: absolute;
    left: 0.9rem;
    bottom: 0.7rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--ember-strong) 82%, transparent);
    backdrop-filter: blur(2px);
  }
  .prob-body {
    display: flex;
    flex-direction: column;
    padding: 1.3rem 1.5rem 1.4rem;
    flex: 1;
  }
  .prob-body h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
  }
  .prob-body p {
    color: var(--color-text-muted);
    margin: 0 0 1.15rem;
    font-size: 0.96rem;
  }
  .prob-tag {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-text-faint);
    text-decoration: none;
  }
  .prob-tag b {
    color: var(--color-accent-strong);
    font-weight: 600;
  }
  .prob-tag span {
    transition: transform 0.15s var(--ease, ease);
  }
  .prob:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--ember) 32%, var(--color-border));
  }
  .prob:hover .prob-photo img {
    transform: scale(1.04);
  }
  .prob:hover .prob-tag span {
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .prob-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .prob-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
