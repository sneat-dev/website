---
// The ecosystem these tools were forged shipping — real Sneat products. Not a
// metric, not a logo wall of customers we don't have: the actual body of work
// the toolkit came out of.
const ecosystem = [
  'Sneat.app', 'Listus', 'Debtus', 'Eventius', 'Calendarius', 'Contactus',
  'Docus', 'Assetus', 'Bookius', 'GameBoard', 'ReQuoter', 'Schoolus',
  'Sizeus', 'Taxus', 'Remindius', 'Localius', 'Formius', 'RSVP&nbsp;Express',
  'Trackus', 'Yardius', 'Sneat.work', 'Sneat.club',
];
const highlight = new Set(['Sneat.app', 'Eventius', 'GameBoard', 'Debtus', 'Sneat.work']);
---

<section id="why" class="section section--ink why">
  <div class="why-fire" aria-hidden="true"></div>
  <div class="container why-grid">
    <div class="why-copy" data-reveal>
      <p class="eyebrow">Why Sneat</p>
      <h2>Forged in the fire.</h2>
      <p>
        Sneat is an ecosystem — a consumer super-app, a work platform, a sports
        platform, and a long tail of focused apps, all over one shared graph.
        Building that as a small team meant leaning hard on AI. And AI, it turns
        out, is only as good as the context you can hand it.
      </p>
      <p>
        So we built the context. Specs that don’t rot. A queryable map of the
        code. Data that lives in Git. The libraries to reuse it all. Nothing here
        is a science project — every tool earns its place by keeping a real,
        growing ecosystem shippable.
      </p>
      <blockquote class="why-quote">
        We didn’t set out to build developer tools. We set out to&nbsp;ship — and
        these are what it took.
      </blockquote>
    </div>

    <div class="why-right">
      <figure class="why-photo" data-reveal>
        <img
          src="/photos/origin.jpg"
          alt="A developer working late at a glowing multi-monitor workstation"
          loading="lazy"
          decoding="async"
          width="720"
          height="1280"
        />
        <figcaption class="mono">2 a.m. · the making</figcaption>
      </figure>

      <div class="why-wall" data-reveal data-reveal-delay="80" aria-hidden="true">
        <div class="wall-glow"></div>
        <div class="wall-chips">
          {
            ecosystem.map((name) => (
              <span class:list={['wchip', 'mono', highlight.has(name) && 'wchip--hot']} set:html={name} />
            ))
          }
        </div>
        <p class="wall-cap mono">the toolkit’s proving ground</p>
      </div>
    </div>
  </div>
</section>

<style>
  .why {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  /* "Forged in the fire" — a panoramic night-fire band behind the header,
     fading into the section's ink. Prominent on mobile (base), subtler on
     desktop (stronger overlay). */
  .why-fire {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: -1;
    height: 460px;
    background-image:
      linear-gradient(
        to bottom,
        rgba(8, 8, 20, 0.38) 0%,
        rgba(8, 8, 20, 0.6) 52%,
        var(--ink-950) 100%
      ),
      url('/photos/why-fire.jpg');
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
  }
  @media (min-width: 901px) {
    .why-fire {
      height: 360px;
      background-image:
        linear-gradient(
          to bottom,
          rgba(8, 8, 20, 0.55) 0%,
          rgba(8, 8, 20, 0.78) 55%,
          var(--ink-950) 100%
        ),
        url('/photos/why-fire.jpg');
    }
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .why-copy p {
    color: #c9caea;
    font-size: 1.05rem;
  }
  .why h2 {
    color: #fff;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .why-quote {
    margin: 1.8rem 0 0;
    padding-left: 1.1rem;
    border-left: 3px solid var(--ember);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.35;
    color: #fff;
    font-style: normal;
  }

  .why-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .why-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid #ffffff1f;
  }
  .why-photo img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: 50% 35%;
    display: block;
    filter: saturate(0.9) brightness(0.92);
  }
  .why-photo figcaption {
    position: absolute;
    left: 0.9rem;
    bottom: 0.7rem;
    font-size: 0.72rem;
    color: #e7e8ff;
    background: #0008;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }
  .why-wall {
    position: relative;
    border: 1px solid #ffffff1a;
    border-radius: var(--radius);
    padding: 1.6rem;
    background: #ffffff08;
    overflow: hidden;
    isolation: isolate;
  }
  .wall-glow {
    position: absolute;
    z-index: -1;
    width: 340px;
    height: 340px;
    right: -110px;
    top: -110px;
    border-radius: 50%;
    background: radial-gradient(circle, #ff6a3d, transparent 68%);
    opacity: 0.35;
    filter: blur(40px);
  }
  .wall-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .wchip {
    font-size: 0.8rem;
    color: #b9bbe0;
    background: #ffffff0f;
    border: 1px solid #ffffff17;
    border-radius: 8px;
    padding: 0.3rem 0.6rem;
  }
  .wchip--hot {
    color: #fff;
    background: color-mix(in srgb, var(--ember) 24%, transparent);
    border-color: color-mix(in srgb, var(--ember) 45%, transparent);
  }
  .wall-cap {
    margin: 1.1rem 0 0;
    font-size: 0.74rem;
    color: #8a8cb6;
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
