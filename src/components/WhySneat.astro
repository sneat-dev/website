---
// The toolkit itself — the dev tools, specs and libraries that came out of the
// fire. On a developer platform this is what belongs here, not the consumer apps
// (those live in the wider Sneat ecosystem). Ties to the pull quote: "these are
// what it took."
const ecosystem = [
  'SpecScore', 'CodeGrapher', 'inGitDB', 'DTQL', 'ModelSpec', 'GraphSpec',
  'OpenVaultDB', 'PolyModel', 'DALgo', 'bots-go-framework', 'WB',
  'SpecScore&nbsp;Studio', 'Sneat&nbsp;CLI', 'Cover100', 'FileTug', 'inMemDB',
];
const highlight = new Set(['SpecScore', 'CodeGrapher', 'inGitDB', 'DTQL', 'WB']);
---

<section id="why" class="section section--ink why">
  <div class="why-fire" aria-hidden="true"></div>
  <div class="container why-grid">
    <div class="why-copy" data-reveal>
      <p class="eyebrow">Why Sneat</p>
      <h2>Forged in the fire.</h2>
      <p>
        Sneat is an ecosystem — a consumer super-app, a work platform, a sports
        platform, and a long tail of focused apps, all over one shared graph.
        Building that as a small team meant leaning hard on AI. And AI, it turns
        out, is only as good as the context you can hand it.
      </p>
      <p>
        So we built the context. Specs that don’t rot. A queryable map of the
        code. Data that lives in Git. The libraries to reuse it all. Nothing here
        is a science project — every tool earns its place by keeping a real,
        growing ecosystem shippable.
      </p>
      <blockquote class="why-quote">
        We didn’t set out to build developer tools. We set out to&nbsp;ship — and
        these are what it took.
      </blockquote>
    </div>

    <div class="why-right">
      <figure class="why-photo" data-reveal>
        <img
          src="/photos/origin.jpg"
          alt="A developer working late at a glowing multi-monitor workstation"
          loading="lazy"
          decoding="async"
          width="720"
          height="1280"
        />
        <figcaption class="mono">2 a.m. · the making</figcaption>
      </figure>

      <div class="why-wall" data-reveal data-reveal-delay="80" aria-hidden="true">
        <div class="wall-chips">
          {
            ecosystem.map((name) => (
              <span class:list={['wchip', 'mono', highlight.has(name) && 'wchip--hot']} set:html={name} />
            ))
          }
        </div>
        <p class="wall-cap mono">— everything it took</p>
      </div>
    </div>
  </div>
</section>

<style>
  .why {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  /* "Forged in the fire" — a panoramic night-fire band behind the header,
     fading into the section's ink. Prominent on mobile (base), subtler on
     desktop (stronger overlay). */
  .why-fire {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: -1;
    height: 460px;
    background-image:
      linear-gradient(
        to bottom,
        rgba(8, 8, 20, 0.38) 0%,
        rgba(8, 8, 20, 0.6) 52%,
        var(--ink-950) 100%
      ),
      url('/photos/why-fire.jpg');
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
  }
  @media (min-width: 901px) {
    .why-fire {
      height: 360px;
      background-image:
        linear-gradient(
          to bottom,
          rgba(8, 8, 20, 0.55) 0%,
          rgba(8, 8, 20, 0.78) 55%,
          var(--ink-950) 100%
        ),
        url('/photos/why-fire.jpg');
    }
  }

  .why-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .why-copy p {
    color: #c9caea;
    font-size: 1.05rem;
  }
  .why h2 {
    color: #fff;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .why-quote {
    margin: 1.8rem 0 0;
    padding-left: 1.1rem;
    border-left: 3px solid var(--ember);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.35;
    color: #fff;
    font-style: normal;
  }

  .why-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .why-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid #ffffff1f;
  }
  .why-photo img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: 50% 35%;
    display: block;
    filter: saturate(0.9) brightness(0.92);
  }
  .why-photo figcaption {
    position: absolute;
    left: 0.9rem;
    bottom: 0.7rem;
    font-size: 0.72rem;
    color: #e7e8ff;
    background: #0008;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }
  /* Bright close-up fire behind the ecosystem tags; the tags are frosted glass
     that blur + mute the flames behind them. */
  .why-wall {
    position: relative;
    border: 1px solid #ffffff2e;
    border-radius: var(--radius);
    padding: 1.5rem;
    overflow: hidden;
    isolation: isolate;
    background-image:
      linear-gradient(180deg, rgba(20, 8, 2, 0.12), rgba(20, 8, 2, 0.34)),
      url('/photos/why-flames.jpg');
    background-size: cover;
    background-position: center;
    box-shadow: inset 0 0 60px rgba(30, 8, 0, 0.35);
  }
  .wall-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .wchip {
    font-size: 0.8rem;
    color: #fff;
    background: rgba(14, 8, 10, 0.34);
    -webkit-backdrop-filter: blur(7px) saturate(0.8);
    backdrop-filter: blur(7px) saturate(0.8);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 8px;
    padding: 0.3rem 0.6rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }
  .wchip--hot {
    color: #fff;
    background: color-mix(in srgb, var(--ember) 30%, rgba(14, 8, 10, 0.34));
    border-color: color-mix(in srgb, var(--ember) 62%, transparent);
  }
  .wall-cap {
    margin: 1.1rem 0 0;
    font-size: 0.74rem;
    color: #fff;
    letter-spacing: 0.04em;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
  }

  @media (max-width: 900px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
    /* The "2 a.m. · the making" photo crowds the stacked mobile layout — drop it
       and let the fire header + the proving-ground wall carry the section. */
    .why-photo {
      display: none;
    }
  }
</style>
