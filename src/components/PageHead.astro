---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<header class="page-head">
  <div class="container">
    {eyebrow && <p class="eyebrow" data-reveal>{eyebrow}</p>}
    <h1 data-reveal data-reveal-delay="40">{title}</h1>
    {lead && <p class="lead page-lead" data-reveal data-reveal-delay="80">{lead}</p>}
    <div class="page-head-extra" data-reveal data-reveal-delay="120"><slot /></div>
  </div>
</header>

<style>
  .page-head {
    padding-top: clamp(3rem, 7vw, 5rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--color-border);
    background:
      radial-gradient(680px 260px at 0% -40%, var(--color-accent-soft), transparent 70%);
  }
  .page-head h1 {
    font-size: clamp(2.2rem, 4.6vw, 3.4rem);
    margin-bottom: 0.9rem;
  }
  .page-lead {
    max-width: 62ch;
    font-size: clamp(1.08rem, 1.5vw, 1.28rem);
  }
  .page-head-extra:empty {
    display: none;
  }
  .page-head-extra {
    margin-top: 1.5rem;
  }
</style>
