---
import { SITE } from '../config';

const pillars = [
  {
    title: 'Open formats',
    body: 'SpecScore, ModelSpec and DTQL are open specifications. The format outlives any one tool — including ours.',
  },
  {
    title: 'Free standard tier',
    body: 'Every tool is fully usable for free in its standard version. Hosted or premium extras may come later; the core stays open.',
  },
  {
    title: 'Own your data',
    body: 'Your context lives in your repository and your vault — git-native, versioned and portable. No lock-in by design.',
  },
];
---

<section id="open-source" class="os">
  <!-- Full-width photo hero: the kitesurfer sits behind the header + CTA, no
       wash. Dark text gets a soft light halo for legibility instead of dimming
       the photo. -->
  <div class="os-hero">
    <div class="os-hero-bg" aria-hidden="true"></div>
    <div class="container os-hero-inner" data-reveal>
      <div class="os-hero-head">
        <p class="eyebrow">Open source</p>
        <h2>Open by default.<br />Yours to keep.</h2>
      </div>
      <p class="os-lede">This isn’t a free tier with a trapdoor. The standard version of everything here is open, and the specs beneath it are open too.</p>
      <div class="os-cta">
        <a class="btn btn-primary" href={SITE.githubOrg} rel="noopener" target="_blank">Star on GitHub</a>
        <a class="btn btn-ghost os-ghost" href="#principles">Read the principles</a>
      </div>
    </div>
  </div>

  <div class="os-pillars-wrap">
    <div class="container">
      <div class="os-pillars-row">
        {
          pillars.map((p, i) => (
            <article class="os-pillar" data-reveal data-reveal-delay={String(i * 80)}>
              <span class="os-mark" aria-hidden="true"></span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .os-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
    min-height: clamp(400px, 44vw, 520px);
    padding-block: clamp(2.75rem, 6vw, 4.5rem);
  }
  .os-hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: url('/photos/open-source-bg.jpg') center 34% / cover no-repeat;
  }
  .os-hero-inner {
    max-width: 100%;
  }
  /* content stays on the left so the rider shows on the right */
  .os-hero-inner > * {
    max-width: 34ch;
  }
  .os-hero .eyebrow {
    color: var(--color-accent-strong);
    text-shadow: 0 1px 10px rgba(255, 255, 255, 0.65);
  }
  .os-hero h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-text);
    text-shadow: 0 1px 16px rgba(255, 255, 255, 0.7), 0 1px 2px rgba(255, 255, 255, 0.6);
  }
  .os-lede {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-text);
    margin: 0;
    text-shadow: 0 1px 12px rgba(255, 255, 255, 0.8), 0 1px 2px rgba(255, 255, 255, 0.7);
  }
  .os-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.7rem;
  }
  /* ghost button needs a backdrop over the photo */
  .os-ghost {
    background: rgba(255, 255, 255, 0.72);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    border-color: rgba(255, 255, 255, 0.9);
  }
  .os-ghost:hover {
    background: #fff;
  }

  .os-pillars-wrap {
    background: var(--color-bg-2);
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }
  .os-pillars-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem 2.5rem;
  }
  .os-pillar {
    padding: 0;
  }
  .os-mark {
    display: block;
    width: 13px;
    height: 13px;
    margin-bottom: 0.8rem;
    border-radius: 3px;
    background: var(--grad-accent);
  }
  .os-pillar h3 {
    margin: 0 0 0.4rem;
    font-size: 1.12rem;
  }
  .os-pillar p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.96rem;
  }

  @media (max-width: 760px) {
    /* Cropping-by-cover is what kept cutting the kite or the rider out of
       frame — no crop math gets that right at every viewport. Instead show
       the photo at its native aspect ratio, full width, nothing cropped,
       as its own band between the header and the lede (not overlaid), so
       there's no way for text to land on top of the rider or the kite. */
    .os-hero {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      overflow: visible;
      min-height: 0;
      padding-block: 1.5rem 0;
    }
    .os-hero-bg {
      position: relative;
      inset: auto;
      z-index: auto;
      order: 2;
      width: 100%;
      aspect-ratio: 1600 / 1066;
      background: url('/photos/open-source-bg.jpg') center / 100% auto no-repeat;
      transform: scaleX(-1);
      margin-block: 1.25rem;
    }
    .os-hero-inner {
      display: contents;
    }
    .os-hero-head {
      order: 1;
      max-width: none;
      padding-inline: 22px;
    }
    .os-lede {
      order: 3;
      max-width: none;
      padding-inline: 22px;
    }
    .os-hero .eyebrow,
    .os-hero h2,
    .os-lede {
      text-shadow: none;
    }
    .os-cta {
      display: none;
    }
    .os-pillars-row {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }
  }
</style>
