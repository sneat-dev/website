---
import { PRINCIPLES } from '../data/principles';
---

<section id="principles" class="section">
  <div class="container">
    <div class="section-head" data-reveal>
      <p class="eyebrow">How we build</p>
      <h2>Opinions, earned by shipping.</h2>
      <p>We’re confident about these because we’ve paid for getting them wrong. We’re humble about them because the work is never finished.</p>
    </div>

    <div class="prin-grid">
      {
        PRINCIPLES.map((p, i) => (
          <article class="prin card" data-reveal data-reveal-delay={String((i % 3) * 70)}>
            <div class="prin-top">
              <span class="prin-mark mono">0{i + 1}</span>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
            <div class="prin-photo">
              <img src={p.photo} alt={p.alt} loading="lazy" decoding="async" width="900" height="563" />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .prin-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .prin {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
  }
  .prin-top {
    padding: 1.5rem 1.5rem 1.3rem;
  }
  .prin-mark {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-accent);
  }
  .prin-top h3 {
    margin: 0.5rem 0 0.5rem;
    font-size: 1.2rem;
  }
  .prin-top p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.96rem;
  }
  .prin-photo {
    margin-top: auto;
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-top: 1px solid var(--color-border);
  }
  .prin-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, color-mix(in srgb, var(--ink-950) 22%, transparent));
    mix-blend-mode: multiply;
    opacity: 0.5;
    transition: opacity 0.3s var(--ease, ease);
  }
  .prin-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.02);
    transition: transform 0.5s var(--ease, ease);
  }
  .prin:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
  }
  .prin:hover .prin-photo img {
    transform: scale(1.04);
  }
  .prin:hover .prin-photo::after {
    opacity: 0.3;
  }

  @media (max-width: 900px) {
    .prin-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .prin-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
