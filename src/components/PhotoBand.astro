---
// Authentic engineering photography — the reality behind the abstractions.
// Sources + licenses recorded in PHOTO_CREDITS.md (all Unsplash License).
const shots = [
  { src: '/photos/whiteboard.jpg', alt: 'Engineers sketching a system on a whiteboard', cap: 'Whiteboarding the architecture' },
  { src: '/photos/debug.jpg', alt: 'A screen of code and terminal output during debugging', cap: 'Chasing the bug that shouldn’t exist' },
  { src: '/photos/codebase.jpg', alt: 'A developer at a multi-monitor workstation reading a large codebase', cap: 'Holding a whole codebase in your head' },
];
---

<section class="section moments">
  <div class="container">
    <div class="section-head center" data-reveal>
      <p class="eyebrow">The work</p>
      <h2>You already know this world.</h2>
      <p>Every tool here comes from a place we’ve actually stood — not a slide deck.</p>
    </div>

    <div class="moments-grid">
      {
        shots.map((s, i) => (
          <figure class="moment" data-reveal data-reveal-delay={String(i * 90)}>
            <div class="moment-img">
              <img src={s.src} alt={s.alt} loading="lazy" decoding="async" width="1000" height="750" />
            </div>
            <figcaption class="mono">{s.cap}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .center {
    text-align: center;
  }
  .moments .section-head.center p {
    margin-inline: auto;
  }
  .moments-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .moment {
    margin: 0;
  }
  .moment-img {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  .moment-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 55%, color-mix(in srgb, var(--ink-950) 30%, transparent));
    mix-blend-mode: multiply;
    opacity: 0.5;
    transition: opacity 0.3s var(--ease, ease);
  }
  .moment-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.02);
    transition: transform 0.5s var(--ease, ease), filter 0.3s ease;
  }
  .moment:hover .moment-img img {
    transform: scale(1.03);
    filter: saturate(1.05) contrast(1.02);
  }
  .moment:hover .moment-img::after {
    opacity: 0.3;
  }
  figcaption {
    margin-top: 0.7rem;
    font-size: 0.8rem;
    color: var(--color-text-faint);
    text-align: center;
  }
  @media (max-width: 720px) {
    .moments-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
